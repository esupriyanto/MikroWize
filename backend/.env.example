# Database
DATABASE_URL=postgresql+asyncpg://mikrowize:secret@localhost:5432/mikrowize

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# MikroTik API
DEFAULT_API_PORT=8728
DEFAULT_SSH_PORT=22

# Encryption key for credentials (Fernet)
CREDENTIAL_ENCRYPTION_KEY=change-me-generate-with-fernet-key
